# =============================================================================
# LLM Configuration
# =============================================================================
# At least one provider API key is required (for the models you use)

# OpenAI (default provider)
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Groq (fast inference)
GROQ_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Ollama (local models - no key needed, just run: ollama serve)
# OLLAMA_API_BASE=http://localhost:11434

# -----------------------------------------------------------------------------
# Model Selection
# -----------------------------------------------------------------------------
# Cheap model: used for simple tasks, tool calling, classification
# Premium model: used for complex planning, multi-step reasoning
#
# Format: provider/model-name (OpenAI models don't need prefix)
# Examples:
#   OpenAI:    gpt-4o-mini, gpt-4o, o3-mini
#   Anthropic: anthropic/claude-3-5-sonnet-20241022, anthropic/claude-3-5-haiku-20241022
#   Google:    gemini/gemini-2.0-flash, gemini/gemini-2.0-pro
#   Groq:      groq/llama-3.3-70b-versatile
#   Ollama:    ollama/llama3.1:8b, ollama/llama3.2:3b

FLO_CHEAP_MODEL=gpt-4o-mini
FLO_PREMIUM_MODEL=gpt-4o

# =============================================================================
# Server
# =============================================================================
FLO_HOST=0.0.0.0
FLO_PORT=8000
FLO_DB_PATH=flo.db
FLO_LOG_LEVEL=info
FLO_ENV=development

# =============================================================================
# Discord Integration
# =============================================================================
DISCORD_BOT_TOKEN=

# =============================================================================
# WhatsApp Integration (Meta Cloud API)
# =============================================================================
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# =============================================================================
# Google APIs (Calendar & Gmail)
# =============================================================================
# Download credentials.json from Google Cloud Console
# On first use, browser opens for OAuth; token saved to token.json
FLO_GOOGLE_CREDENTIALS_PATH=credentials.json
FLO_GOOGLE_TOKEN_PATH=token.json

# =============================================================================
# Web Search
# =============================================================================
# Provider: tavily or serpapi
FLO_SEARCH_PROVIDER=tavily
FLO_SEARCH_API_KEY=
